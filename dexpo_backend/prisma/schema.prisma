generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model investments {
  investment_id   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id         String?   @db.Uuid
  stall_id        String?   @db.Uuid
  amount_invested Decimal   @db.Decimal(12, 2)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  stalls          stalls?   @relation(fields: [stall_id], references: [stall_id], onDelete: Cascade, onUpdate: NoAction)
  users           users?    @relation(fields: [user_id], references: [u_id], onDelete: Cascade, onUpdate: NoAction)
}

model stalls {
  stall_id      String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email_id      String        @unique
  name          String
  organisations org_type
  about         String?
  invested_sum  Decimal?      @default(0.00) @db.Decimal(12, 2)
  investments   investments[]
}

model users {
  u_id        String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email_id    String        @unique
  password    String
  sum         Decimal?      @default(0.00) @db.Decimal(12, 2)
  investments investments[]
}

enum org_type {
  CFI_Project
  Competetion_Team
  Startup
}
